from fastapi import APIRouter, Depends, HTTPException, Request  
from sqlalchemy.orm import Session  
  
from app.core.database import get_db  
from app.models.customer import Customer  
from app.models.user import User  
from app.schemas.customer import CustomerCreate, CustomerUpdate, CustomerOut  
from app.api.deps import get_current_user  
from app.api.permission import ensure_customer_access  
from app.services.audit_service import write_audit_log  
  
router = APIRouter()  
  
@router.post("", response_model=CustomerOut)  
def create_customer(  
    payload: CustomerCreate,  
    request: Request,  
    db: Session = Depends(get_db),  
    current_user: User = Depends(get_current_user),  
):  
    customer = Customer(  
        **payload.model_dump(),  
        created_by=current_user.id,  
        updated_by=current_user.id,  
        owner_user_id=payload.owner_user_id or current_user.id,  
    )  
    db.add(customer)  
    db.commit()  
    db.refresh(customer)  
  
    write_audit_log(  
        db,  
        user_id=current_user.id,  
        module="customers",  
        action="create",  
        target_type="customer",  
        target_id=str(customer.id),  
        detail_json={"nickname": customer.nickname},  
        ip_address=request.client.host if request.client else None,  
        user_agent=request.headers.get("user-agent"),  
    )  
    return customer  
  
@router.get("")  
def list_customers(  
    db: Session = Depends(get_db),  
    current_user: User = Depends(get_current_user),  
    keyword: str = "",  
    page: int = 1,  
    page_size: int = 20,  
):  
    query = db.query(Customer)  
  
    if current_user.role != "admin":  
        query = query.filter(Customer.owner_user_id == current_user.id)  
  
    if keyword:  
        query = query.filter(Customer.nickname.ilike(f"%{keyword}%"))  
  
    total = query.count()  
    items = query.order_by(Customer.id.desc()).offset((page - 1) * page_size).limit(page_size).all()  
    return {"total": total, "items": items}  
  
@router.get("/{customer_id}", response_model=CustomerOut)  
def get_customer(  
    customer_id: int,  
    request: Request,  
    db: Session = Depends(get_db),  
    current_user: User = Depends(get_current_user),  
):  
    customer = db.query(Customer).filter(Customer.id == customer_id).first()  
    if not customer:  
        raise HTTPException(status_code=404, detail="Customer not found")  
  
    ensure_customer_access(current_user, customer.owner_user_id)  
  
    write_audit_log(  
        db,  
        user_id=current_user.id,  
        module="customers",  
        action="view_detail",  
        target_type="customer",  
        target_id=str(customer.id),  
        detail_json={"nickname": customer.nickname},  
        ip_address=request.client.host if request.client else None,  
        user_agent=request.headers.get("user-agent"),  
    )  
    return customer

