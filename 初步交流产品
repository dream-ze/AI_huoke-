from fastapi import APIRouter, Depends  
from sqlalchemy.orm import Session  
from sqlalchemy import func  
  
from app.core.database import get_db  
from app.models.customer import Customer  
from app.models.publish_record import PublishRecord  
from app.models.user import User  
from app.api.deps import get_current_user  
  
router = APIRouter()  
  
@router.get("/home")  
def home_dashboard(  
    db: Session = Depends(get_db),  
    current_user: User = Depends(get_current_user),  
):  
    customer_query = db.query(Customer)  
    publish_query = db.query(PublishRecord)  
  
    if current_user.role != "admin":  
        customer_query = customer_query.filter(Customer.owner_user_id == current_user.id)  
        publish_query = publish_query.filter(PublishRecord.owner_user_id == current_user.id)  
  
    today_new_customers = customer_query.filter(  
        func.date(Customer.created_at) == func.current_date()  
    ).count()  
  
    today_pending_follow = customer_query.filter(  
        Customer.customer_status.in_(["new", "following"])  
    ).count()  
  
    today_publish_count = publish_query.filter(  
        func.date(PublishRecord.publish_time) == func.current_date()  
    ).count()  
  
    return {  
        "today_new_customers": today_new_customers,  
        "today_pending_follow": today_pending_follow,  
        "today_publish_count": today_publish_count,  
        "today_high_risk_contents": 0,  
        "today_wechat_add_count": 0,  
        "week_valid_leads": 0,  
    }

