## 五、合规审核逻辑第一版

第一版不要太复杂，先做 **规则匹配 + 风险评分**。

### compliance_service.py

from sqlalchemy.orm import Session  
from app.models.compliance_rule import ComplianceRule  
  
def check_content_compliance(db: Session, content: str) -> dict:  
    rules = db.query(ComplianceRule).filter(ComplianceRule.status == "active").all()  
  
    issues = []  
    score = 0  
  
    for rule in rules:  
        if rule.keyword and rule.keyword in content:  
            issues.append({  
                "rule_name": rule.rule_name,  
                "keyword": rule.keyword,  
                "description": rule.description,  
                "suggestion": rule.replace_suggestion,  
                "risk_level": rule.risk_level,  
            })  
            if rule.risk_level == "high":  
                score += 30  
            elif rule.risk_level == "medium":  
                score += 15  
            else:  
                score += 5  
  
    if score >= 60:  
        risk_level = "high"  
    elif score >= 25:  
        risk_level = "medium"  
    else:  
        risk_level = "low"  
  
    return {  
        "risk_level": risk_level,  
        "score": score,  
        "issues": issues,  
    }

