from fastapi import APIRouter, Depends, HTTPException  
from pydantic import BaseModel  
from sqlalchemy.orm import Session  
from app.core.database import get_db  
from app.models.content_asset import ContentAsset  
from app.services.rewrite_service import build_rewrite_prompt  
from app.services.ollama_service import call_ollama  
  
router = APIRouter()  
  
class RewriteGenerateIn(BaseModel):  
    asset_id: int  
    target_platform: str  
    tone: str = "口语化"  
    audience: str = "普通咨询用户"  
  
@router.post("/generate")  
def generate_rewrite(payload: RewriteGenerateIn, db: Session = Depends(get_db)):  
    asset = db.query(ContentAsset).filter(ContentAsset.id == payload.asset_id).first()  
    if not asset:  
        raise HTTPException(status_code=404, detail="Asset not found")  
  
    prompt = build_rewrite_prompt(  
        raw_text=asset.raw_text or "",  
        target_platform=payload.target_platform,  
        tone=payload.tone,  
        audience=payload.audience,  
    )  
    content = call_ollama(prompt)  
    return {  
        "asset_id": asset.id,  
        "title": asset.title,  
        "content": content,  
    }

