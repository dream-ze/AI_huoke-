{
  "name": "zhihuokeke-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "智获客桌面端",
  "main": "electron/main.cjs",
  "author": "zhihuokeke",
  "scripts": {
    "dev:web": "vite",
    "dev:web:lan": "vite --host 0.0.0.0 --port 5173",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "vite build",
    "build": "npm run build:web",
    "test": "vitest",
    "test:run": "vitest run",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173",
    "dist": "npm run build:web && electron-builder --win nsis"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^2.15.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.2",
    "vite": "^5.4.14",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.zhihuokeke.desktop",
    "productName": "智获客",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/backend.exe",
        "to": "backend/backend.exe"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智获客"
    }
  }
}
