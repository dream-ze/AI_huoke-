# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@localhost/zhihuokeke
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_NAME=zhihuokeke
ENABLE_STARTUP_USER_SEQUENCE_HEALTHCHECK=True

# JWT
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Settings
API_TITLE=智获客 API
API_VERSION=0.1.0
DEBUG=False

# CORS
# 生产环境禁止使用 ["*"]，请配置明确来源白名单
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Bootstrap user（生产建议关闭）
ENABLE_BOOTSTRAP_TEST_USER=False

# AI Models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2-chinese
USE_CLOUD_MODEL=False

# Fire Engine (if using)
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-mini-260215
ARK_TIMEOUT_SECONDS=60
ARK_VISION_RATE_LIMIT_PER_MINUTE=20
ARK_VISION_RATE_LIMIT_WINDOW_SECONDS=60
INSIGHT_BATCH_ANALYZE_RATE_LIMIT_PER_MINUTE=6
INSIGHT_BATCH_ANALYZE_RATE_LIMIT_WINDOW_SECONDS=60

# Redis (distributed rate limiting)
USE_REDIS_RATE_LIMIT=True
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_KEY_PREFIX=zhihuokeke

# File Upload
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

# WeCom
WECOM_WEBHOOK_URL=

# Operations
# 部署后请访问 /api/system/ops/health 与 /api/system/ops/readiness 验证数据库、Redis、Ollama 状态
