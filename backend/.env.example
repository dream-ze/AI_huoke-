# ============================================================
# 智获客后端环境配置
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 修改所有标记为 [必填] 的配置项
# 3. 生产环境必须修改所有默认密码和密钥
# ============================================================

# ---- 数据库配置 [必填] ----
# PostgreSQL连接URL，生产环境必须使用强密码
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/zhihuokeke
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=                    # [必填] 请设置安全的数据库密码，禁止使用默认密码
DATABASE_NAME=zhihuokeke
# 是否自动创建数据库表（生产环境建议关闭）
DB_AUTO_CREATE_TABLES=False
# 启动时检查用户ID序列健康状态
ENABLE_STARTUP_USER_SEQUENCE_HEALTHCHECK=True

# ---- 安全配置 [必填] ----
# JWT密钥，至少32字符，生产环境必须使用随机生成的强密钥
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=                           # [必填] 请生成安全密钥
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- API配置 ----
API_TITLE=智获客 API
API_VERSION=0.1.0
DEBUG=false                           # [生产必填] 生产环境必须设为false

# ---- CORS跨域配置 ----
# 生产环境禁止使用 ["*"]，请配置明确来源白名单
# 多个域名用逗号分隔，格式：["http://localhost:5173","https://your-domain.com"]
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ---- 初始化配置 ----
# 是否创建测试用户（生产环境建议关闭）
ENABLE_BOOTSTRAP_TEST_USER=False

# ---- AI模型配置 ----
# 本地Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
# 是否优先使用云端模型（火山方舟）
USE_CLOUD_MODEL=true

# ---- 火山方舟配置（云端LLM）[可选] ----
# 火山方舟API密钥
ARK_API_KEY=                          # [可选] 火山方舟API密钥
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-1-5-pro-32k-250115
# 种子模型配置（用于特定场景）
ARK_SEED_API_KEY=                     # [可选] 种子模型API密钥
ARK_SEED_MODEL=                       # [可选] 种子模型ID
# 嵌入模型配置
ARK_EMBEDDING_MODEL=doubao-embedding-large-text-240915
ARK_TIMEOUT_SECONDS=60

# ---- 火山云API配置 [可选] ----
VOLC_ACCESS_KEY_ID=                   # [可选] 火山云Access Key ID
VOLC_SECRET_ACCESS_KEY=               # [可选] 火山云Secret Access Key

# ---- 限流配置 ----
# 视觉模型限流（每分钟请求数）
ARK_VISION_RATE_LIMIT_PER_MINUTE=20
ARK_VISION_RATE_LIMIT_WINDOW_SECONDS=60
# 批量分析限流（每分钟请求数）
INSIGHT_BATCH_ANALYZE_RATE_LIMIT_PER_MINUTE=6
INSIGHT_BATCH_ANALYZE_RATE_LIMIT_WINDOW_SECONDS=60

# ---- Redis配置 ----
REDIS_URL=redis://localhost:6379/0
# 是否启用Redis限流
USE_REDIS_RATE_LIMIT=true
RATE_LIMIT_KEY_PREFIX=zhihuokeke

# ---- Celery异步任务配置 ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- 前端地址 ----
FRONTEND_URL=http://localhost:5173

# ---- 文件上传配置 ----
# 最大上传文件大小（字节），默认50MB
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

# ---- 第三方集成 [可选] ----
# 企业微信机器人Webhook地址（用于消息通知）
WECOM_WEBHOOK_URL=                    # [可选] 企业微信机器人Webhook

# ---- 运维提示 ----
# 部署后请访问以下端点验证系统状态：
# - /health - 健康检查
# - /api/system/ops/health - 系统组件健康状态
# - /api/system/ops/readiness - 数据库、Redis、Ollama连接状态
