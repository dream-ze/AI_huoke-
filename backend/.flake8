[flake8]
max-line-length = 120
exclude = 
    .git,
    __pycache__,
    alembic/versions,
    build,
    dist,
    *.egg-info
ignore = 
    E501,
    W503,
    E203,
    E226,
    E402,
    E712,
    E722,
    E741,
    F401,
    F541,
    F841,
    W291,
    W293,
per-file-ignores =
    __init__.py:F401
