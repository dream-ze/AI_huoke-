# ============================================================
# 智获客 - 生产环境配置（服务器：116.62.86.160）
# 部署前把本文件复制为 .env 并修改密码
# ============================================================

# ── 数据库（内部 Docker 网络，hostname = postgres）──────────
DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@postgres:5432/zhihuokeke
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_NAME=zhihuokeke
ENABLE_STARTUP_USER_SEQUENCE_HEALTHCHECK=True

# ── JWT（务必修改为随机字符串）────────────────────────────
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── API ────────────────────────────────────────────────────
API_TITLE=智获客 API
API_VERSION=0.1.0
DEBUG=False
DB_AUTO_CREATE_TABLES=False

# ── CORS：生产环境必须使用白名单，禁止 "*" ───────────────
CORS_ORIGINS=["http://116.62.86.160:8000","http://116.62.86.160:5173","http://localhost:5173","http://127.0.0.1:5173"]

# ── 启动阶段是否自动创建测试用户（生产建议关闭）────────────
ENABLE_BOOTSTRAP_TEST_USER=False

# ── Ollama AI 模型（内部 Docker 网络）────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2:1.5b
USE_CLOUD_MODEL=True

# ── 火山引擎（可选）──────────────────────────────────────
ARK_API_KEY=CHANGE_ME_ARK_API_KEY
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-1-5-pro-32k-250115
ARK_SEED_API_KEY=CHANGE_ME_ARK_SEED_API_KEY
ARK_SEED_MODEL=doubao-seed-2-0-mini-260215
ARK_EMBEDDING_MODEL=doubao-embedding-large-text-240915
ARK_TIMEOUT_SECONDS=60
VOLC_ACCESS_KEY_ID=CHANGE_ME_VOLC_ACCESS_KEY_ID
VOLC_SECRET_ACCESS_KEY=CHANGE_ME_VOLC_SECRET_ACCESS_KEY

# ── Redis 限流/缓存（生产建议开启）───────────────────────
USE_REDIS_RATE_LIMIT=True
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_KEY_PREFIX=zhihuokeke

# ── 文件上传 ───────────────────────────────────────────────
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=./uploads

# ── 企业微信与通知（可选）────────────────────────────────
WECOM_WEBHOOK_URL=

# ── 浏览器采集配置 ────────────────────────────────────────
BROWSER_HEADLESS=True

# ── Celery 异步任务队列 ───────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── 前端URL（用于企微消息中的链接）────────────────────────
FRONTEND_URL=http://116.62.86.160:8000
