[Unit]
Description=Browser Collector Service (Playwright)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/www/browser_collector
Environment="PYTHONPATH=/www/browser_collector"
EnvironmentFile=/www/browser_collector/.env
ExecStart=/usr/local/bin/uvicorn app.main:app --host 0.0.0.0 --port 8005 --workers 1
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
