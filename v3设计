async def run_task(task):
    try:
        collector = CollectorFactory.get_collector(task.platform)

        if task.task_type == "search":
            data = await collector.search(task.keyword, 20)

        elif task.task_type == "detail":
            data = await collector.detail(task.url)

        elif task.task_type == "comments":
            data = await collector.comments(task.url, 20)

        save_results(task.task_id, data)

        update_task_status(task.task_id, "success")

    except Exception as e:
        handle_task_error(task, e)
重试机制（必须有）
def handle_task_error(task, error):
