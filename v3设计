四、核心设计（最关键）
1️⃣ BaseCollector（统一基类）

这是你整个系统“能不能扩展”的核心。

from abc import ABC, abstractmethod

class BaseCollector(ABC):

    platform: str

    @abstractmethod
    async def search(self, keyword: str, max_items: int):
        pass

    @abstractmethod
    async def detail(self, url: str):
        pass

    async def comments(self, url: str, max_comments: int = 20):
        raise NotImplementedError

    async def health_check(self):
        return {"platform": self.platform, "status": "unknown"}
2️⃣ Collector Factory
class CollectorFactory:

    @staticmethod
    def get_collector(platform: str):
        if platform == "xiaohongshu":
            return XHSCollector()
        elif platform == "douyin":
            return DouyinCollector()
        else:
            raise ValueError("Unsupported platform")
