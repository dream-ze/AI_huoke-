微博
网页内容页

它们都要实现同一套接口。

建议基类定义
class BaseCollector(ABC):
    platform: str

    @abstractmethod
    async def search(self, keyword: str, max_items: int, **kwargs) -> list[dict]:
        pass

    @abstractmethod
    async def detail(self, url: str | None = None, source_id: str | None = None, **kwargs) -> dict:
        pass

    async def comments(self, url: str | None = None, source_id: str | None = None, max_comments: int = 20, **kwargs) -> list[dict]:
        raise NotImplementedError

    async def health_check(self) -> dict:
        return {"platform": self.platform, "status": "unknown"}

    async def close(self):
        pass
每个平台都要输出统一结构

比如 search 必须返回统一字段：

{
