四、核心处理代码（最小实现）
1️⃣ 入库 pipeline
def process_content(raw):
    # 1. 存原始
    source_id = save_source(raw)

    # 2. 清洗
    content = raw.get("content_text") or raw.get("snippet") or ""
    title = raw.get("title") or content[:20]

    normalized_id = save_normalized({
        "source_content_id": source_id,
        "title": title,
        "content_text": content,
        "content_preview": content[:80],
        "content_hash": hash(content),
        "platform": raw.get("platform"),
        "comment_count": raw.get("comment_count", 0),
    })

    # 3. 生成素材
    hot = calc_hot_level(raw.get("comment_count", 0))
    lead, reason = calc_lead_level(title + content)

    material_id = save_material({
        "normalized_content_id": normalized_id,
        "title": title,
        "content_text": content,
        "content_preview": content[:80],
        "platform": raw.get("platform"),
        "comment_count": raw.get("comment_count", 0),
        "hot_level": hot,
        "lead_level": lead,
        "lead_reason": reason,
    })

    # 4. 自动进入知识库（关键点）
    create_knowledge(material_id, title, content, raw.get("platform"))

    return material_id
2️⃣ 自动分类（最小版本）
def create_knowledge(material_id, title, content, platform):

    text = title + content

    # 一级分类（必须做）
    account_type = "顾问号" if "怎么办" in text else "科普号"

    if "逾期" in text:
        audience = "负债逾期"
    elif "贷款" in text:
        audience = "贷款人群"
    else:
        audience = "泛人群"

    content_type = "正文"

    doc_id = save_knowledge_document({
        "material_item_id": material_id,
        "platform": platform,
        "account_type": account_type,
        "target_audience": audience,
        "content_type": content_type,
        "title": title,
        "summary": content[:100],
        "content_text": content,
    })

    # 分片
    chunks = split_text(content, 300)

    for i, chunk in enumerate(chunks):
        embedding = embed(chunk)

        save_chunk({
            "knowledge_document_id": doc_id,
            "chunk_text": chunk,
            "chunk_index": i,
            "embedding": embedding,
        })
五、混合检索（必须按顺序）
def retrieve(query, platform, account_type, audience):

    # 1. 结构过滤（必须先做）
    candidates = filter_docs(
        platform=platform,
        account_type=account_type,
        target_audience=audience
    )

    # 2. 关键词筛选
    candidates = keyword_match(candidates, query)

    # 3. 向量检索
    vector = embed(query)
    results = vector_search(candidates, vector)

    # 4. 排序（固定规则）
    results = sorted(results, key=lambda x: (
        x.similarity,
        x.comment_count,
        x.lead_level == "high"
    ), reverse=True)

    return results[:5]
六、生成编排（核心）
def generate(material_id, platform, account_type, audience):

    material = get_material(material_id)

    refs = retrieve(
        query=material["content_text"],
        platform=platform,
        account_type=account_type,
        audience=audience
    )

    rules = get_rules(platform, account_type, audience)

    prompt = get_prompt(platform, account_type, audience)

    final_prompt = build_prompt(
        material=material,
        refs=refs,
        rules=rules,
        template=prompt
    )

    output = call_llm(final_prompt)

    save_generation(material_id, output)

    return output
