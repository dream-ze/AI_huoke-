九、更新时间触发器

PostgreSQL 没有 MySQL 那种自动 ON UPDATE CURRENT_TIMESTAMP，
所以建议你加一个更新时间函数。

CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

绑定到表：

DROP TRIGGER IF EXISTS trg_collector_task_updated_at ON collector_task;
CREATE TRIGGER trg_collector_task_updated_at
BEFORE UPDATE ON collector_task
FOR EACH ROW
EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_inbox_item_updated_at ON inbox_item;
CREATE TRIGGER trg_inbox_item_updated_at
BEFORE UPDATE ON inbox_item
FOR EACH ROW
EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_rewrite_record_updated_at ON rewrite_record;
CREATE TRIGGER trg_rewrite_record_updated_at
BEFORE UPDATE ON rewrite_record
FOR EACH ROW
EXECUTE FUNCTION update_updated_at_column();
