    if relevance == 0:
        return "discard"

    # 待审核
    if quality < 50:
        return "review"

    if lead < 20:
        return "review"

    # 直接入收件箱
    return "pending"
六、完整流程代码（核心伪代码）
def ingest_items(items):

    results = {
        "inserted": 0,
        "review": 0,
        "discard": 0,
        "duplicate": 0
    }

    for raw in items:

        # 1. 基础校验
        if not is_valid(raw):
            continue

        # 2. 去重
        if is_duplicate(raw):
            results["duplicate"] += 1
            continue

        # 3. 标准化
        item = normalize(raw)

        # 4. 打分
        item["quality_score"] = calc_quality(item)
        item["relevance_score"] = calc_relevance(item)
        item["lead_score"] = calc_lead_score(item)

        # 5. 状态判定
        item["inbox_status"] = decide_status(item)

        # 6. 入库
        db.insert(item)

        if item["inbox_status"] == "pending":
            results["inserted"] += 1
        elif item["inbox_status"] == "review":
            results["review"] += 1
        else:
            results["discard"] += 1

    return results
