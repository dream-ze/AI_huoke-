import re


def parse_metric_text(text: str | None, keyword: str):
    if not text:
        return None

    pattern = rf"{keyword}\s*([0-9]+(?:\.[0-9]+)?[万wW]?)"
    match = re.search(pattern, text)
    if not match:
        return None

    raw = match.group(1).lower()
    if "万" in raw or "w" in raw:
        number = float(raw.replace("万", "").replace("w", ""))
        return int(number * 10000)
    return int(float(raw))


def calc_engagement_score(
    like_count=None,
    comment_count=None,
    favorite_count=None,
    share_count=None
):
    score = 0.0
    score += (like_count or 0) * 1.0
    score += (comment_count or 0) * 2.0
    score += (favorite_count or 0) * 1.5
    score += (share_count or 0) * 2.5
    return round(score, 2)
