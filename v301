from copy import deepcopy
from app.schemas.content import ContentItem
from app.utils.text_util import clean_text, build_snippet, build_preview
from app.utils.image_util import choose_cover_url
from app.utils.metric_util import calc_engagement_score


class ContentNormalizer:

    def normalize(self, item: ContentItem) -> ContentItem:
        obj = deepcopy(item)

        obj.title = clean_text(obj.title)
        obj.author_name = clean_text(obj.author_name)
        obj.snippet = clean_text(obj.snippet)
        obj.content_text = clean_text(obj.content_text)

        if not obj.snippet and obj.content_text:
            obj.snippet = build_snippet(obj.content_text, max_len=100)

        if obj.content_text:
            obj.content_preview = build_preview(obj.content_text, max_len=120)

        if not obj.cover_url and obj.content_image_urls:
            obj.cover_url = choose_cover_url(obj.content_image_urls)

        obj.data_quality = self._build_data_quality(obj)
        obj.quality_score = self._calc_quality_score(obj)
        obj.engagement_score = calc_engagement_score(
            like_count=obj.like_count,
            comment_count=obj.comment_count,
            favorite_count=obj.favorite_count,
            share_count=obj.share_count,
        )

        return obj

    def merge_list_and_detail(self, base: ContentItem, detail_data: dict) -> ContentItem:
        merged = base.model_copy(deep=True)

        for key, value in detail_data.items():
            if key == "field_source":
                continue
            if value is not None and value != [] and value != "":
                setattr(merged, key, value)

        merged.field_source.update(detail_data.get("field_source", {}))
        return self.normalize(merged)

    def _build_data_quality(self, item: ContentItem) -> dict:
        return {
            "has_title": bool(item.title),
            "has_snippet": bool(item.snippet),
            "has_content_text": bool(item.content_text),
            "has_publish_time": bool(item.publish_time),
            "has_cover_url": bool(item.cover_url),
            "content_image_count": len(item.content_image_urls or []),
            "has_like_count": item.like_count is not None,
            "has_comment_count": item.comment_count is not None,
        }

    def _calc_quality_score(self, item: ContentItem) -> float:
        score = 0.0
        if item.title:
            score += 0.15
        if item.snippet:
            score += 0.10
        if item.content_text:
            score += 0.25
        if item.publish_time:
            score += 0.15
        if item.cover_url:
            score += 0.10
        if item.content_image_urls:
            score += 0.10
        if item.like_count is not None:
            score += 0.10
        if item.comment_count is not None:
            score += 0.05
        return round(min(score, 1.0), 4)
