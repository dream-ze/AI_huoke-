from typing import Dict, Any
from app.utils.text_util import clean_text
from app.utils.time_util import parse_publish_time
from app.utils.image_util import filter_content_images
from app.utils.metric_util import parse_metric_text


class XiaohongshuDetailParser:

    def parse(self, page) -> Dict[str, Any]:
        result = {
            "content_text": None,
            "publish_time": None,
            "author_avatar_url": None,
            "content_image_urls": [],
            "like_count": None,
            "comment_count": None,
            "favorite_count": None,
            "share_count": None,
            "field_source": {}
        }

        content_text = self._extract_content_text(page)
        if content_text:
            result["content_text"] = clean_text(content_text)
            result["field_source"]["content_text"] = "detail_dom"

        publish_time, publish_source = self._extract_publish_time(page)
        if publish_time:
            result["publish_time"] = publish_time
            result["field_source"]["publish_time"] = publish_source

        avatar = self._extract_author_avatar(page)
        if avatar:
            result["author_avatar_url"] = avatar
            result["field_source"]["author_avatar_url"] = "detail_dom"

        image_urls = self._extract_content_images(page)
        if image_urls:
            result["content_image_urls"] = image_urls
            result["field_source"]["content_image_urls"] = "detail_dom"

        metrics = self._extract_metrics(page)
        result.update(metrics)
        result["field_source"].update({
            k: v for k, v in metrics.pop("field_source", {}).items()
        })

        return result

    def _extract_content_text(self, page) -> str:
        selectors = [
            ".note-content",
            ".desc",
            "[class*=content]",
            "[class*=desc]",
        ]
        for selector in selectors:
            try:
                text = page.locator(selector).first.inner_text(timeout=1500).strip()
                if text:
                    return text
            except Exception:
                continue
        return ""

    def _extract_publish_time(self, page):
        # 1. DOM 优先
        dom_selectors = [
            ".publish-time",
            "[class*=publish]",
            "[class*=time]",
        ]
        for selector in dom_selectors:
            try:
                text = page.locator(selector).first.inner_text(timeout=1000).strip()
                dt = parse_publish_time(text)
                if dt:
                    return dt, "dom"
            except Exception:
                pass

        # 2. script/json
        try:
            content = page.content()
            dt = parse_publish_time(content)
            if dt:
                return dt, "script"
        except Exception:
            pass

        # 3. 全文兜底
        try:
            body_text = page.locator("body").inner_text(timeout=1500)
            dt = parse_publish_time(body_text)
            if dt:
                return dt, "text_fallback"
        except Exception:
            pass

        return None, ""

    def _extract_author_avatar(self, page) -> str:
        selectors = [
            ".author img",
            ".user img",
            "[class*=avatar] img",
            "img[class*=avatar]",
        ]
        for selector in selectors:
            try:
                url = page.locator(selector).first.get_attribute("src", timeout=1000)
                if url:
                    return url
            except Exception:
                continue
        return ""

    def _extract_content_images(self, page):
        urls = []
        selectors = [
            ".note-content img",
            ".swiper img",
            "[class*=content] img",
            "[class*=image] img",
        ]
        for selector in selectors:
            try:
                count = page.locator(selector).count()
                for i in range(count):
                    el = page.locator(selector).nth(i)
                    url = (
                        el.get_attribute("src") or
                        el.get_attribute("data-src") or
                        ""
                    ).strip()
                    if url:
                        urls.append(url)
            except Exception:
                continue
        return filter_content_images(urls)

    def _extract_metrics(self, page):
        result = {
            "like_count": None,
            "comment_count": None,
            "favorite_count": None,
            "share_count": None,
            "field_source": {}
        }
        try:
            body_text = page.locator("body").inner_text(timeout=1500)
            like_count = parse_metric_text(body_text, "点赞")
            comment_count = parse_metric_text(body_text, "评论")
            favorite_count = parse_metric_text(body_text, "收藏")
            share_count = parse_metric_text(body_text, "分享")

            if like_count is not None:
                result["like_count"] = like_count
                result["field_source"]["like_count"] = "text_fallback"
            if comment_count is not None:
                result["comment_count"] = comment_count
                result["field_source"]["comment_count"] = "text_fallback"
            if favorite_count is not None:
                result["favorite_count"] = favorite_count
                result["field_source"]["favorite_count"] = "text_fallback"
            if share_count is not None:
                result["share_count"] = share_count
                result["field_source"]["share_count"] = "text_fallback"
        except Exception:
            pass
        return result
