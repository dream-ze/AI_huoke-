        self.detail_parser = XiaohongshuDetailParser()
        self.normalizer = ContentNormalizer()

    def collect(self, req: CollectRequest) -> Tuple[List[ContentItem], CollectStats]:
        stats = CollectStats()
        items = []

        with create_browser() as browser:
            page = browser.new_page()
            self._open_search(page, req.keyword)

            cards = self._get_cards(page, req.max_items)
            for card in cards:
                try:
                    item = self.list_parser.parse_card(card)

                    if req.need_detail:
                        detail_data = self._fetch_detail_data(page, item.url)
                        item = self.normalizer.merge_list_and_detail(item, detail_data)
                        stats.detail_success += 1
                    else:
                        item = self.normalizer.normalize(item)

                    items.append(item)
                except Exception as e:
                    stats.detail_failed += 1
                    fail_item = ContentItem(
                        source="xiaohongshu",
                        source_id="",
                        url="",
                        parse_status="failed",
                        raw_data={"error": str(e)}
                    )
                    items.append(fail_item)

        return items, stats

