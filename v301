            page.goto(url, wait_until="domcontentloaded", timeout=req.timeout_sec * 1000)

            detail_data = self.detail_parser.parse(page)
            item = ContentItem(
                source="xiaohongshu",
                source_id=req.source_id or self._extract_source_id(url),
                url=url,
            )
            return self.normalizer.merge_list_and_detail(item, detail_data)

