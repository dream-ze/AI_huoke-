import re
from datetime import datetime


DATE_PATTERNS = [
    r"(\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2}:\d{2})",
    r"(\d{4}-\d{2}-\d{2}\s+\d{2}:\d{2})",
    r"(\d{4}-\d{2}-\d{2})",
    r"(\d{4}/\d{2}/\d{2}\s+\d{2}:\d{2}:\d{2})",
    r"(\d{4}/\d{2}/\d{2}\s+\d{2}:\d{2})",
    r"(\d{4}/\d{2}/\d{2})",
]


def parse_publish_time(text: str | None):
    if not text:
        return None

    for pattern in DATE_PATTERNS:
        match = re.search(pattern, text)
        if not match:
            continue

        raw = match.group(1)
        raw = raw.replace("/", "-")

        for fmt in [
            "%Y-%m-%d %H:%M:%S",
            "%Y-%m-%d %H:%M",
            "%Y-%m-%d",
        ]:
            try:
                dt = datetime.strptime(raw, fmt)
                if fmt == "%Y-%m-%d":
                    dt = dt.replace(hour=0, minute=0, second=0)
                return dt
            except ValueError:
                continue
    return None
