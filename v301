import re


def clean_text(text: str | None) -> str | None:
    if not text:
        return None
    text = text.replace("\u200b", " ").replace("\xa0", " ")
    text = re.sub(r"\s+", " ", text).strip()
    return text or None


def build_snippet(text: str | None, max_len: int = 100) -> str | None:
    text = clean_text(text)
    if not text:
        return None
    return text[:max_len]


def build_preview(text: str | None, max_len: int = 120) -> str | None:
    text = clean_text(text)
    if not text:
        return None
    return text[:max_len]
image_util.py
from urllib.parse import urlsplit, urlunsplit

BAD_IMAGE_KEYWORDS = [
    "avatar",
    "icon",
    "logo",
    "emoji",
    "badge",
    "profile",
    "fe-platform",
]


def normalize_image_url(url: str) -> str:
    if not url:
        return ""
    parts = urlsplit(url)
    return urlunsplit((parts.scheme, parts.netloc, parts.path, "", ""))


def is_bad_image(url: str) -> bool:
    lower = url.lower()
    return any(word in lower for word in BAD_IMAGE_KEYWORDS)


def filter_content_images(urls: list[str]) -> list[str]:
    result = []
    seen = set()

    for url in urls:
        if not url:
            continue
        url = normalize_image_url(url)
        if is_bad_image(url):
            continue
        if url in seen:
            continue
        seen.add(url)
        result.append(url)

    return result[:9]


def choose_cover_url(urls: list[str]) -> str | None:
    if not urls:
        return None
    return urls[0]
