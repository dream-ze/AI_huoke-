                "author_name": "list_dom",
                "cover_url": "list_dom",
            },
            raw_data={}
        )

    def _safe_text(self, card, selector: str) -> str:
        try:
            el = card.locator(selector).first
            return el.inner_text(timeout=1000).strip()
        except Exception:
            return ""

    def _safe_attr(self, card, selector: str, attr: str) -> str:
        try:
            el = card.locator(selector).first
            return (el.get_attribute(attr, timeout=1000) or "").strip()
        except Exception:
            return ""

    def _extract_source_id(self, url: str) -> str:
        if not url:
            return ""
        parts = url.rstrip("/").split("/")
        return parts[-1] if parts else ""
