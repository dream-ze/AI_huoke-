    def run(self, req: CollectRequest) -> CollectResponse:
        start = time.time()

        collector = CollectorFactory.get(req.platform)
        items, stats = collector.collect(req)

        normalized_items = [self.normalizer.normalize(item) for item in items]

        stats.total = len(normalized_items)
        stats.success = sum(1 for x in normalized_items if x.parse_status == "success")
        stats.failed = stats.total - stats.success
        stats.duration_ms = int((time.time() - start) * 1000)

        return CollectResponse(
            success=True,
            platform=req.platform,
            keyword=req.keyword,
            total=len(normalized_items),
            items=normalized_items,
            stats=stats,
        )
