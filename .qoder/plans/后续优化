from app.skills import SkillRegistry, BaseSkill, SkillContext, SkillResult
from app.services.mvp_knowledge_service import MvpKnowledgeService
from app.services.ai_service import AIService


@SkillRegistry.register
class ReplySkill(BaseSkill):
    """评论/私信回复建议技能"""
    
    name = "reply_suggestion"
    version = "1.0.0"
    description = "基于知识库生成评论/私信回复建议"
    
    async def execute(self, context: SkillContext) -> SkillResult:
        input_data = context.input_data
        user_message = input_data.get("message", "")
        platform = input_data.get("platform", "xiaohongshu")
        conversation_history = input_data.get("history", [])
        
        # 1. 意图识别
        intent = await self._identify_intent(user_message)
        
        # 2. 知识库检索
        from app.core.database import SessionLocal
        db = SessionLocal()
        try:
            knowledge_service = MvpKnowledgeService(db)
            knowledge_results = knowledge_service.search(
                query=user_message,
                top_k=3,
                filters={"platform": platform}
            )
        finally:
            db.close()
        
        # 3. 生成回复建议
        suggestions = await self._generate_suggestions(
            user_message=user_message,
            intent=intent,
            knowledge_context=knowledge_results,
            conversation_history=conversation_history
        )
        
        # 4. 判断是否需要人工接管
        should_takeover = self._check_takeover_conditions(intent, user_message)
        
        return SkillResult(
            success=True,
            data={
                "intent": intent["type"],
                "confidence": intent["confidence"],
                "suggestions": suggestions,
                "should_takeover": should_takeover,
                "takeover_reason": intent.get("takeover_reason")
            }
        )
    
    async def _identify_intent(self, message: str) -> dict:
        """意图识别"""
        # 高意向关键词
        high_intent_keywords = ["利率", "额度", "征信", "放款", "申请", "多久", "条件"]
        # 风险关键词
        risk_keywords = ["投诉", "骗子", "举报", "曝光", "黑心"]
        
        message_lower = message.lower()
        
        if any(kw in message for kw in risk_keywords):
            return {"type": "complaint", "confidence": 0.9, "takeover_reason": "检测到投诉/负面内容"}
        
        if any(kw in message for kw in high_intent_keywords):
            return {"type": "high_intent_inquiry", "confidence": 0.85}
        
        if "?" in message or "？" in message or "吗" in message:
            return {"type": "general_inquiry", "confidence": 0.7}
        
        return {"type": "casual", "confidence": 0.6}
    
    async def _generate_suggestions(
        self, 
        user_message: str, 
        intent: dict,
        knowledge_context: list,
        conversation_history: list
    ) -> list:
        """生成回复建议"""
        # 组装上下文
        context_text = "\n".join([
            f"- {item.get('content', '')[:200]}" 
            for item in knowledge_context[:3]
        ]) if knowledge_context else "无相关知识库内容"
        
        prompt = f"""用户消息：{user_message}
用户意图：{intent['type']}
相关知识：
{context_text}

请生成3个回复建议，要求：
1. 专业友好，不要过度承诺
2. 引导用户提供更多信息或私信咨询
3. 符合平台调性

输出格式：
回复1：...
回复2：...
回复3：...
"""
        
        from app.integrations.ark import get_ark_client
        client = get_ark_client()
        response = await client.chat(prompt)
        
        # 解析回复
        suggestions = []
        for line in response.split("\n"):
            if line.startswith("回复"):
                suggestions.append(line.split("：", 1)[-1].strip())
        
        return suggestions[:3] if suggestions else ["感谢您的关注，详情可以私信我了解~"]
    
    def _check_takeover_conditions(self, intent: dict, message: str) -> bool:
        """判断是否需要人工接管"""
        if intent["type"] == "complaint":
            return True
        if intent["type"] == "high_intent_inquiry" and intent["confidence"] > 0.8:
            return True
        if len(message) > 200:  # 长消息可能是复杂问题
            return True
        return False
