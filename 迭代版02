from app.collectors.xiaohongshu_collector import XiaohongshuCollector
from app.schemas.detail import CollectDetailRequest, CollectDetailResponse


class DetailService:
    def __init__(self) -> None:
        self.collectors = {
            "xiaohongshu": XiaohongshuCollector(),
        }

    async def fetch_detail(self, req: CollectDetailRequest) -> CollectDetailResponse:
        collector = self.collectors.get(req.platform)
        if not collector:
            return CollectDetailResponse(
                success=False,
                platform=req.platform,
                url=req.url or "",
                source_id=req.source_id or "",
                data=None,
                message=f"暂不支持的平台: {req.platform}",
            )

        try:
            result = await collector.fetch_detail(req)

            return CollectDetailResponse(
                success=result.get("success", False),
                platform=req.platform,
                url=result.get("url", req.url or ""),
                source_id=result.get("source_id", req.source_id or ""),
                data=result.get("data"),
                message=result.get("message", ""),
            )
        except Exception as e:
            return CollectDetailResponse(
                success=False,
                platform=req.platform,
                url=req.url or "",
                source_id=req.source_id or "",
                data=None,
                message=f"详情补采失败: {str(e)}",
            )
